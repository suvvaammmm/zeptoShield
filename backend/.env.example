# ZeptoShield Backend — Environment Variables
# Copy this file to .env and fill in your values

# MongoDB (local or Atlas)
MONGO_URI=mongodb://localhost:27017/zeptoshield

# Razorpay Sandbox Keys
# Get from: https://dashboard.razorpay.com → Settings → API Keys → Test Mode
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# ML Service URL (Python FastAPI)
ML_URL=http://localhost:8000

# Server port
PORT=5000
