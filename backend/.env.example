# ── MongoDB ────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/zeptoshield
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/zeptoshield
MONGO_URI=mongodb://localhost:27017/zeptoshield

# ── Razorpay (sandbox) ─────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# ── Twilio Verify (real SMS OTP) ───────────────────────────────────────────
# 1. Create account at https://twilio.com
# 2. Go to Verify → Create a Service
# 3. Copy Account SID, Auth Token, and Verify Service SID (starts with VA...)
# Leave blank to use demo OTP mode (code: 1234)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Admin phones ───────────────────────────────────────────────────────────
# Comma-separated list of phone numbers that get admin access after OTP
# e.g. 9876543210,9123456789
ADMIN_PHONES=9876543210

# ── ML Service ─────────────────────────────────────────────────────────────
ML_URL=http://localhost:8000

# ── App ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
